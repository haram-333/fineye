rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if user has admin custom claim
    function isAdmin() {
      return isAuthenticated() &&
        (
          request.auth.token.admin == true ||
          request.auth.token.email == "admin@fineye.com"
        );
    }
    
    // User invoices - users can only access their own invoices
    match /user_invoices/{invoiceId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // User profiles - users can read/write their own profile
    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && userId == request.auth.uid);
      allow write: if isAuthenticated() && userId == request.auth.uid;
    }

    // Per-user activity tracking used for admin monitoring
    match /user_activity/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && userId == request.auth.uid);
      allow create, update: if isAuthenticated() && userId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // User notification settings - users can manage their own settings
    match /user_notification_settings/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }
    
    // User notifications - users can read/write their own notifications
    match /user_notifications/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
      
      // Allow reading/writing individual notifications within the user's collection
      match /notifications/{notificationId} {
        allow read, write: if isAuthenticated() && userId == request.auth.uid;
      }
    }
    
    // FCM tokens - users can manage their own tokens
    match /user_fcm_tokens/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }
    
    // Tax settings - users can manage their own tax settings
    match /user_tax_settings/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }
      
    // User settings - users can manage their own settings
    match /user_settings/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }
      
    // Security settings - users can manage their own security settings
    match /user_security_settings/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }
      
    // App settings - users can manage their own app settings
    match /user_app_settings/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }
    
    // Compliance data - users can manage their own compliance data
    match /user_compliance/{userId} {
      allow read, write: if isAuthenticated() && userId == request.auth.uid;
    }
  }
}
